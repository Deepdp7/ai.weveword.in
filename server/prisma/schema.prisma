generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id                    String         @id @default(uuid())
  name                  String
  email                 String         @unique
  passwordHash          String
  role                  String         @default("user") // 'user', 'admin'
  avatar                String         @default("")
  bio                   String         @default("")
  phone                 String         @default("")
  isVerified            Boolean        @default(false)
  plan                  String         @default("free") // 'free', 'basic', 'pro', 'elite'
  planExpiresAt         DateTime?
  credits               Int            @default(0)
  
  // Flattened aiDailyUsage
  aiUsageSahadev        Int            @default(0)
  aiUsageKrishna        Int            @default(0)
  aiUsageVedbaash       Int            @default(0)
  aiUsageLastResetAt    DateTime       @default(now())

  storageUsed           Int            @default(0) // in bytes
  savedSignatures       String         @default("[]") // JSON string of array
  isBanned              Boolean        @default(false)
  referralCode          String?        @unique
  referredById          String?
  lastLoginAt           DateTime?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  referredBy            User?          @relation("UserReferrals", fields: [referredById], references: [id])
  referrals             User[]         @relation("UserReferrals")

  files                 File[]
  handwritings          Handwriting[]
  notifications         Notification[]
  payments              Payment[]
  projects              Project[]
  transactions          Transaction[]
  adminTasks            AdminTask[]    @relation("AdminAction")
  targetedAdminTasks    AdminTask[]    @relation("TargetAction")
  aiChats               AIChat[]
  adImpressions         AdImpression[]
}

model AIChat {
  id        String   @id @default(uuid())
  userId    String
  mentor    String   // 'sahadev', 'krishna', 'vedbaash'
  messages  String   @default("[]") // JSON string of messages array to avoid complex relation
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, mentor])
}

model AdImpression {
  id            String   @id @default(uuid())
  userId        String
  adType        String   // '15sec', '30sec'
  creditsEarned Int
  platform      String   // 'web', 'android'
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id])
}

model AdminTask {
  id            String   @id @default(uuid())
  adminId       String
  action        String
  targetUserId  String
  details       String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  admin         User     @relation("AdminAction", fields: [adminId], references: [id])
  targetUser    User     @relation("TargetAction", fields: [targetUserId], references: [id])
}

model Coupon {
  id           String   @id @default(uuid())
  code         String   @unique
  type         String   // 'fixed_credits', 'percentage_bonus', 'free_plan'
  value        Int
  maxUses      Int      @default(1)
  usedCount    Int      @default(0)
  perUserLimit Int      @default(1)
  expiresAt    DateTime
  createdBy    String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model File {
  id           String   @id @default(uuid())
  userId       String
  toolSource   String?
  fileName     String
  fileUrl      String
  fileType     String
  size         Int
  publicId     String?
  originalName String?
  isDeleted    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id])
}

model Handwriting {
  id            String   @id @default(uuid())
  userId        String
  name          String   @default("My Script")
  fontSize      Float    @default(24)
  color         String   @default("#000000")
  letterSpacing Float    @default(1)
  lineHeight    Float    @default(1.5)
  tilt          Float    @default(0)
  roughness     Float    @default(1)
  inkColor      String   @default("#000000")
  fontFamily    String   @default("cursive")
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String   @default("info") // 'info', 'success', 'warning', 'error', 'ad'
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id])
}

model OTP {
  id        String   @id @default(uuid())
  email     String
  code      String
  purpose   String   // 'forgot_password', 'email_verification'
  attempts  Int      @default(0)
  expiresAt DateTime
}

model Payment {
  id                     String   @id @default(uuid())
  userId                 String
  type                   String   // 'credit_pack', 'subscription'
  amount                 Int
  credits                Int
  planId                 String?
  razorpayOrderId        String
  razorpayPaymentId      String?
  razorpaySubscriptionId String?
  status                 String   @default("created") // 'created', 'captured', 'failed'
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  user                   User     @relation(fields: [userId], references: [id])
}

model Project {
  id             String           @id @default(uuid())
  userId         String
  title          String
  template       String           @default("school")
  isDeleted      Boolean          @default(false)
  lastExportedAt DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  user           User             @relation(fields: [userId], references: [id])
  sections       ProjectSection[]
}

model ProjectSection {
  id        String  @id @default(uuid())
  projectId String
  sectionId String  // The client side id
  title     String
  order     Int
  content   String  @default("")

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ToolPricing {
  id        String   @id @default(uuid())
  toolKey   String   @unique
  credits   Int
  updatedBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Transaction {
  id                String   @id @default(uuid())
  userId            String
  type              String   // 'purchase', 'ad_reward', 'tool_usage', 'subscription', 'refund', 'bonus', 'coupon', 'referral'
  description       String
  credits           Int
  balanceAfter      Int
  razorpayOrderId   String?
  razorpayPaymentId String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User     @relation(fields: [userId], references: [id])
}
